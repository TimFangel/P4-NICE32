--- FUNCTIONS ---
func x:
param t0
t2 := 20 + t0
t1 := t2
RET t1
end func


--- SETUP ---
t3 := 9
PORT_SETUP DIGITAL INPUT 2


--- MAIN ---
L0:
t5 := CALL x, 10
t6 := t5
t4 := t6
t7 := true
t8 := t4 > 20
t9 := t7 && t8
IF_FALSE t9 GOTO L1
L1:
t11 := -10
t10 := t11
t13 := t10 * 10
t14 := t13 + t4
t15 := t14 - 5
t12 := t15
COMPR t3 2 1000
GOTO L0
