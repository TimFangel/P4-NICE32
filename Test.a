; B0
FUNC        a            ; FUNC a:; PARAM a2
MOV        a2,  a2       ; a2 := a2
RET        a2            ; RET a2

; B1
.L0:                     ; L0:
MOVI       a2,   2       ; a2 := 2
a2                       ; a2 := CALL a, a2
MOV        a2,  a2       ; a2 := a2
J         .L0            ; GOTO L0

