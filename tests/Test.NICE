setup {
    int a = 2;

    component c {
        port: 2;
        protocol: digital;
        interval: 10;
        direction: input;

        bool x = true;
    }
}

functions {
    int func f(bool c) {
        int b = 0;
        if (c) {
            b = 2;
        } else {
            b = 1;
        }
        return b;
    }
}

main {
    int b = a + f(c.x);
}