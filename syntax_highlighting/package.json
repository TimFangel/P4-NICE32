{
    "name": "nice-language",
    "displayName": "NICE Language",
    "version": "0.0.1",
    "repository": {},
    "engines": {
        "vscode": "^1.80.0"
    },
    "contributes": {
        "languages": [
            {
                "id": "nice",
                "extensions": [
                    ".nice",
                    ".NICE"
                ],
                "aliases": [
                    "NICE"
                ]
            }
        ],
        "grammars": [
            {
                "language": "nice",
                "scopeName": "source.nice",
                "path": "./syntaxes/nice.tmLanguage.json"
            }
        ]
    }
}
